rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function currentRole() {
      return me().role != null ? me().role : (me().cargo != null ? me().cargo : '');
    }

    function normalizedTenantId() {
      return me().tenantId != null ? me().tenantId : 'default';
    }

    function isSupport() {
      return signedIn() && currentRole() == 'suporte' && me().active != false;
    }

    function isAdmin() {
      return signedIn() && (currentRole() == 'admin' || currentRole() == 'suporte') && me().active != false;
    }

    function isOperator() {
      return signedIn() && (currentRole() == 'admin' || currentRole() == 'suporte' || currentRole() == 'vendedor') && me().active != false;
    }

    function tenantMatches(tenantId) {
      return signedIn() && normalizedTenantId() == tenantId;
    }

    match /users/{userId} {
      allow read: if isOperator();
      allow create: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow update: if isAdmin() || (signedIn() && request.auth.uid == userId);
    }

    match /settings/{docId} {
      allow read, write: if isOperator();
    }

    match /parkingSpaces/{docId} {
      allow read, write: if isOperator();
    }

    match /priceSettings/{docId} {
      allow read: if isOperator();
      allow write: if isAdmin();
    }

    match /cashRegisters/{docId} {
      allow read: if isOperator();
      allow create, update: if isOperator();
    }

    match /parkingTickets/{docId} {
      allow read: if isOperator();
      allow create, update: if isOperator();
    }

    match /monthlyCustomers/{docId} {
      allow read: if isOperator();
      allow create, update: if isOperator();
    }

    match /client_tokens/{tokenId} {
      allow list, create, update, delete: if isSupport();
      allow get: if isSupport() || (resource.data.status == 'PENDENTE' && resource.data.expiraEm > request.time);
      allow update: if isSupport() || (
        signedIn()
        && resource.data.status == 'PENDENTE'
        && resource.data.expiraEm > request.time
        && request.resource.data.status == 'UTILIZADO'
      );
    }

    match /tenants/{tenantId}/{document=**} {
      allow read, write: if tenantMatches(tenantId) && isOperator();
    }
  }
}
